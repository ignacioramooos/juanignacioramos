MERCADOPAGO_ACCESS_TOKEN=

# Optional if your frontend is hosted separately from the API.
# VITE_MERCADOPAGO_PREFERENCE_URL=https://your-api-domain.com/api/mercadopago-preference

# Optional for the daily opportunity scout automation email delivery.
# Cloudflare route: deploy cloudflare/opportunity-scout-email, set the same
# DIGEST_SEND_TOKEN as a Worker secret, then add the Worker URL here.
OPPORTUNITY_SCOUT_WORKER_URL=
DIGEST_SEND_TOKEN=

# Brevo fallback route: create a Brevo v3 API key under SMTP & API, then make
# sure the sender is verified in Brevo before the automation runs.
BREVO_API_KEY=
OPPORTUNITY_SCOUT_FROM_EMAIL=
OPPORTUNITY_SCOUT_FROM_NAME=Ignacio Opportunity Scout
OPPORTUNITY_SCOUT_TO_EMAIL=ignacio@juanignacioramos.com,macagutierrez71@gmail.com,valentinaoundjian@gmail.com
